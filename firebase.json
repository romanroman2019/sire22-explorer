{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "enabled": true,
        "oAuthBrandDisplayName": "Sire22 Explorer",
        "supportEmail": "romanroma@gmail.com",
        "authorizedDomains": [
          "localhost",
          "my-sire2.web"
        ]
      }
    }
  }
}
